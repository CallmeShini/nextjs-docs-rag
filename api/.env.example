# ==============================================================
# LLM Provider — choose ONE block and fill in your credentials
# ==============================================================

# --- Option A: Azure AI Foundry (default) ---
LLM_PROVIDER=azure_foundry
AZURE_FOUNDRY_API_KEY=your-key-here
# Accepted formats:
# 1. Resource root:
#    https://<your-resource>.services.ai.azure.com/models
# 2. Full portal target URL:
#    https://<your-resource>.services.ai.azure.com/models/chat/completions?api-version=2024-05-01-preview
AZURE_FOUNDRY_BASE_URL=https://<your-resource>.services.ai.azure.com/models
AZURE_FOUNDRY_API_VERSION=2024-05-01-preview
LLM_MODEL=grok-4-fast-non-reasoning

# --- Option B: xAI Grok (direct) ---
# LLM_PROVIDER=xai
# XAI_API_KEY=xai-...
# LLM_MODEL=grok-3

# --- Option C: OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# LLM request timeout in seconds (default: 30)
LLM_TIMEOUT=30

# Final answer language:
# - english     => always answer in English
# - match_query => mirror the user query language
# - pt / es / fr / ... => force a specific language tag
RESPONSE_LANGUAGE=english

# ==============================================================
# Embeddings (LOCAL — no API key needed)
# ==============================================================
# Optional: set HF_TOKEN to avoid anonymous Hugging Face rate limits
# during the first local model downloads.
# HF_TOKEN=hf_...
EMBEDDING_MODEL=all-MiniLM-L6-v2    # fast, 384-dim, great retrieval quality
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ==============================================================
# Paths
# ==============================================================
CHROMA_PATH=./data/chroma_db
NEXTJS_REPO_PATH=./data/nextjs-repo
BM25_CORPUS_PATH=./data/bm25_corpus.json
CHUNKS_PATH=./data/chunks.json

# ==============================================================
# Retrieval
# ==============================================================
MAX_ITERATIONS=3
PLANNER_EARLY_STOP_ENABLED=true
PLANNER_EARLY_STOP_MIN_EVIDENCE_SCORE=0.76
PLANNER_EARLY_STOP_MIN_EVIDENCE_ITEMS=4
PLANNER_EARLY_STOP_MAX_EVIDENCE_DELTA=0.02
PLANNER_EARLY_STOP_MIN_STALLED_CYCLES=1
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5
MAX_CHUNK_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
CHUNK_READER_MAX_WORDS=400
EVIDENCE_MAX_WORDS=500

# ==============================================================
# API
# ==============================================================

# Rate limiting — requests per window per IP (slowapi format)
# Examples: "10/minute", "100/hour", "5/second"
RATE_LIMIT=10/minute

# CORS allowed origins — comma-separated, or "*" for all (dev only)
# Production: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# Preload graph + local models during API startup to reduce first-request latency
PRELOAD_MODELS_ON_STARTUP=true

# ==============================================================
# Logging
# ==============================================================

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log format: "text" (human-readable, default) | "json" (structured, use in prod)
LOG_FORMAT=text
